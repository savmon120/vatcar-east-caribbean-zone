# Drupal 11

# Ignore vendor directory (installed by Composer)
/vendor/

# Ignore user-uploaded files and private files
sites/*/files
sites/*/private

# Ignore multi-site test environment
sites/simpletest

# Ignore local settings (contains DB credentials)
sites/*/*settings*.php
!sites/*/default.settings.php
sites/*/*services*.yml
!sites/*/default.services.yml

# Ignore Drush site aliases
drush/sites/

# -----------------------------------------------
# DDEV local environment
# -----------------------------------------------
# Keep .ddev/config.yaml in git but ignore local overrides and generated files
.ddev/.gitignore
.ddev/db_snapshots/
.ddev/addon-metadata/
.ddev/homeadditions/
.ddev/providers/
.ddev/commands/web/
.ddev/commands/db/
.ddev/xhprof/

# -----------------------------------------------
# OS / editor artifacts
# -----------------------------------------------
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo

# Windows Zone Identifier files (created when downloading on Windows)
*:Zone.Identifier

# -----------------------------------------------
# Composer
# -----------------------------------------------
.composer/
