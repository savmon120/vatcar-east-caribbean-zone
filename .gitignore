# Drupal 11

# Ignore vendor directory (installed by Composer)
/vendor/

# Ignore user-uploaded files and private files
sites/*/files
sites/*/private

# Ignore multi-site test environment
sites/simpletest

# Ignore local settings (contains DB credentials)
sites/*/*settings*.php
!sites/*/default.settings.php
sites/*/*services*.yml
!sites/*/default.services.yml

# Ignore Drush site aliases
drush/sites/

# -----------------------------------------------
# DDEV local environment
# -----------------------------------------------
# Ignore everything in .ddev/ except config.yaml — DDEV regenerates everything
# else on `ddev start`. The generated .ddev/.gitignore is also excluded here so
# DDEV can manage it freely without git noise.
.ddev/*
!.ddev/config.yaml

# -----------------------------------------------
# OS / editor artifacts
# -----------------------------------------------
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo

# Windows Zone Identifier files (created when downloading on Windows)
*:Zone.Identifier

# -----------------------------------------------
# Composer
# -----------------------------------------------
.composer/
