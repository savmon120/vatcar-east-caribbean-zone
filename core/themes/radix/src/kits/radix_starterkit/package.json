{
	"name": "radix_starterkit",
	"description": "A custom Radix subtheme, based on Bootstrap 5.",
	"private": true,
	"engines": {
		"npm": ">=8.0",
		"node": ">=18.0",
		"yarn": ">=1.22"
	},
	"license": "MIT",
	"scripts": {
		"postinstall": "find node_modules/ -name '*.info' -type f -delete",
		"dev": "node build-dev.mjs",
		"watch": "node watch.mjs",
		"biome:format": "biome format --write src/ components/",
		"biome:lint": "biome lint --apply src/ components/",
		"biome:check": "biome check --apply src/ components/",
		"stylint": "npx stylelint '**/*.scss'",
		"stylint-fix": "npx stylelint '**/*.scss' --fix",
		"build": "node build.mjs"
	},
	"devDependencies": {
		"@biomejs/biome": "^1.4.1",
		"@popperjs/core": "^2.11.8",
		"autoprefixer": "^10.4.5",
		"bootstrap": "^5.3.3",
		"browser-sync": "^3.0.4",
		"cross-env": "^7.0.3",
		"dotenv": "^16.3.1",
		"drupal-radix-cli": "^1.0.6",
		"esbuild": "^0.28.0",
		"esbuild-plugin-copy": "^2.1.1",
		"esbuild-sass-plugin": "^3.7.0",
		"fast-glob": "^3.3.2",
		"postcss": "^8.4.31",
		"sass": "^1.63.6",
		"stylelint": "^14.1.0",
		"stylelint-config-prettier": "^9.0.3",
		"stylelint-config-recess-order": "^3.0.0",
		"stylelint-config-standard-scss": "^6.1.0"
	},
	"dependencies": {
		"bootstrap-icons": "^1.13.1"
	}
}
